# Google Gemini API Key - Get one from https://aistudio.google.com/ (Required if LLM_BACKEND=gemini)
GEMINI_API_KEY=your_gemini_api_key_here

# Alibaba DashScope API Key - Get one from DashScope Model Studio (Required if LLM_BACKEND=qwen)
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# LLM Backend to use ('gemini' or 'qwen')
# Note: MCP Tool calling is only supported with the 'gemini' backend for now (help welcome for 'qwen'!)
LLM_BACKEND=gemini

# Custom Model Selection (Optional Defaults)
# GEMINI_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
# QWEN_MODEL=qwen3-omni-flash-realtime

# Custom Voice Selection (Optional Defaults)
# GEMINI_VOICE=Aoede
# QWEN_VOICE=Cherry

CLIENT_AUTH_TOKEN=your_client_auth_token_here

HOST=127.0.0.1
PORT=3000
ADMIN_PASSWORD=your_admin_password_here
INVALID_TEST_TOKEN=your_invalid_test_token_here

# For local testing, see .env.example.local
# For servers behind Nginx, use your public domain and wss://
MQTT_ENDPOINT=mqtt://your-example-domain.com:1883
WEBSOCKET_URL_FOR_ALLOWED_DEVICE=wss://your-example-domain.com/xiaozhi/v1/
