# --- API Keys ---

# Google Gemini API Key - Get one from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Alibaba DashScope API Key (Qwen3) - Get one from DashScope Model Studio
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# Llama / Local Model Server URL (Optional if using LFM)
LIQUID_SERVER_URL=http://127.0.0.1:8080/v1/chat/completions


# --- Default Session Configuration ---

# Initial LLM Backend to use ('gemini', 'qwen_realtime', 'llama_liquid_interleaved', etc.)
LLM_BACKEND=gemini

# Optional: Default Model & Voice Overrides
# GEMINI_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
# GEMINI_VOICE=Aoede
# QWEN_MODEL=qwen3-omni-flash-realtime
# QWEN_VOICE=Cherry
# LLAMA_MODEL=llama-liquid-interleaved
# LLAMA_VOICE=UK female


# --- Server & Auth Configuration ---

CLIENT_AUTH_TOKEN=someverylongandrandomlygeneratedtoken
ADMIN_PASSWORD=admin123

# Local Network Configuration
# IMPORTANT: Use your machine's local IP address (e.g., 192.168.1.42 or 10.0.0.101)
# Do NOT use 'localhost' if you want other devices on your WiFi to connect.
HOST=10.0.0.101
PORT=3000

# The URL the device will use to connect to the WebSocket after discovery
# For local development without SSL, use 'ws://' and your local IP.
WEBSOCKET_URL_FOR_ALLOWED_DEVICE=ws://10.0.0.101:3000/xiaozhi/v1

# Device Specifics (Optional, used for auto-registration/identification)
ALLOWED_MAC_ADDRESS=00:00:00:00:00:00
ALLOWED_DEVICE_UUID=your-device-uuid-here

# MQTT Endpoint (Currently placeholder, but should match HOST)
MQTT_ENDPOINT=10.0.0.101
